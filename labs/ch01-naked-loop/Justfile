# Ch1 — The Naked Loop
set shell := ["bash", "-cu"]

default:
    @just --list

# Checkpoint for a level: 0=bench (online), 1-4=levels (offline), 5=hardening bonus
check n:
    @python3 checks/check.py {{n}}

# Cheat code: write level N's reference code into the live tree, then run its checkpoint
solve n:
    @python3 checks/solve.py {{n}}

# Copy the hint implementations into the live tree (for testing the demo without writing it yourself)
use-hints:
    cp starter/loop_hint.py ../../budo/budo/core/loop.py
    cp starter/k8s_hint.py  ../../budo/budo/tools/k8s.py
    @echo "✓ hints copied into budo/budo/{core/loop.py,tools/k8s.py}. Run 'just demo' to test."
    @echo "  Reset to skeletons: git -C ../.. checkout -- budo/budo/core/loop.py budo/budo/tools/k8s.py"

# Inject the failure: a typo'd PAYMENT_SERVICE_ADDR on checkoutservice
break:
    ./chaos/checkout-bad-env.sh
    kubectl -n shop rollout status deploy/checkoutservice --timeout=90s

# Run YOUR agent against the broken shop (uses the live tree in ../../budo)
demo:
    cd ../../budo && export BUDO_DEBUG=1 && PYTHONPATH=. python3 -m budo logs \
      "Users report checkout is failing in the shop namespace. Find the root cause."

# Same demo, but dial the verbosity: quiet | info | debug | trace
demo-at level="info":
    cd ../../budo && PYTHONPATH=. python3 -m budo --log-level {{level}} logs \
      "Users report checkout is failing in the shop namespace. Find the root cause."

# Ask budo a custom question. Usage: just ask "why is X failing?" [level]
#   just ask "investigate cartservice"
#   just ask "investigate cartservice" debug
ask question level="info":
    cd ../../budo && PYTHONPATH=. python3 -m budo --log-level {{level}} logs "{{question}}"

# Restore peace
heal:
    kubectl -n shop set env deployment/checkoutservice PAYMENT_SERVICE_ADDR=paymentservice:50051
    kubectl -n shop rollout status deploy/checkoutservice --timeout=90s

# The break-it exercise: flood the context (see chapter)
flood:
    kubectl -n shop logs deploy/loadgenerator --tail=-1 | head -c 400000 > /tmp/flood.log
    @echo "wrote /tmp/flood.log — now try feeding an agent 400KB and watch it drown"
